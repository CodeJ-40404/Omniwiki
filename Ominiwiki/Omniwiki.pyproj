    <Content Include="static\style.css" />
    <Content Include="templates\404.html" />
    <Content Include="templates\all_pages.html" />
    <Content Include="templates\base.html" />
    <Content Include="templates\comments_data.json" />
    <Content Include="templates\create.html" />
    <Content Include="templates\discussions.html" />
    <Content Include="templates\edit.html" />
    <Content Include="templates\history.html" />
    <Content Include="templates\hot_discussions.html" />
    <Content Include="templates\index.html" />
    <Content Include="templates\login.html" />
    <Content Include="templates\my_discussions.html" />
    <Content Include="templates\profile.html" />
    <Content Include="templates\recent_discussions.html" />
    <Content Include="templates\register.html" />
    <Content Include="templates\search.html" />
    <Content Include="templates\tags.html" />
    <Content Include="templates\tag_pages.html" />
    <Content Include="templates\wiki_page.html" />
  </ItemGroup>
